<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="sale_report">
        <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="row">
                            <div class="col-4">
                                <h5>Customer:</h5>
                                <span t-field="docs.customer_id"/>
                            </div>
                            <div class="col-4">
                                <h5>Start Date:</h5>
                                <span t-field="docs.start_date"/>
                            </div>
                            <div class="col-4">
                                <h5>End Date:</h5>
                                <span t-field="docs.end_date"/>
                            </div>
                        </div>
                        <br/>
                        <hr/>
                        <br/>
                        <table class="table">
                            <thead><h3>Customer Orders</h3></thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Description</th>
                                    <th>Quantity</th>
                                    <th>Unit Price</th>
                                    <th>Taxes</th>
                                    <th>Amount</th>
                                </tr>
                            <tbody>
                                <t t-set="order_qty" t-value="0"/>
                                <t t-set="total_amount" t-value="0"/>
                                <t t-foreach="docs.action_get_sale_report_data()" t-as="order">
                                        <div class="row">
                                            <t t-foreach="order.order_line" t-as="line">
                                                <tr>
                                                <div class="col-2"><td><span t-field="order.name"/></td></div>
                                                <div class="col-2"><td><span t-field="line.name"/></td></div>
                                                 <div class="col-2"><td><span t-field="line.product_uom_qty"/></td></div>
                                                <div class="col-2"><td><span t-field="line.price_unit"/></td></div>
                                                <div class="col-2"><td><span t-field="line.tax_id"/></td></div>
                                                <div class="col-2"><td><span t-field="line.price_subtotal"/></td></div>
                                                </tr>
                                                <t t-set="order_qty" t-value="order_qty + line.product_uom_qty"/>
                                                <t t-set="total_amount" t-value="total_amount + line.price_subtotal"/>
                                            </t>
                                        </div>
                                </t>
                                <tr>
                                <td colspan="2" class="text-end">Total:</td>
                                <td class="text-start"><t t-esc="order_qty"/></td>
                                    <td> </td>
                                    <td> </td>
                                <td class="text-start"><t t-esc="total_amount"/></td>
                                </tr>
                            </tbody>

                        </table>
                    </div>
                </t>
        </t>
    </template>
</odoo>
