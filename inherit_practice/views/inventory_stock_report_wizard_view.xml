<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_inventory_stock_report_wiz_form" model="ir.ui.view">
    <field name="name">inventory.stock.report</field>
    <field name="model">inventory.stock.report.wiz</field>
    <field name="arch" type="xml">
        <form string="Inventory Stock Report Wizard">
            <group>
                <field name="product_id"/>
                <field name="date"/>
            </group>
            <footer>
                <button name="action_get_record" string="Apply" type="object" class="btn-primary"/>
                <button string="Cancel" class="btn-secondary" special="cancel"/>
            </footer>
        </form>
    </field>
</record>
      <record id="action_inventory_stock_report_wiz" model="ir.actions.act_window">
        <field name="name">Inventory Stock Report</field>
        <field name="res_model">inventory.stock.report.wiz</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
 <menuitem id="menu_inventory_stock_report"
              name="Inventory Stock Report"
              action="action_inventory_stock_report_wiz"
              parent="stock.menu_warehouse_report"
                  sequence="350"
    />
</odoo>