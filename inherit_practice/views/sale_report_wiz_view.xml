<?xml version="1.0" encoding="utf-8" ?>
<odoo>

<record id="view_sale_report_wiz_form" model="ir.ui.view">
    <field name="name">sale.report.wiz.form</field>
    <field name="model">sale.report.wiz</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <group>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="customer_id"/>
                </group>
            </sheet>
             <footer>
                    <button name="action_download_pdf_report"
                            type="object"
                            string="Process"
                            class="btn-warning"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
        </form>
    </field>
    </record>

     <record id="action_sale_report_wiz" model="ir.actions.act_window">
        <field name="name">Sale Report</field>
        <field name="res_model">sale.report.wiz</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
      <menuitem id="menu_sale_report_wiz"
                name="Sale Report"
                action="action_sale_report_wiz"
                parent="sale.menu_sale_report"
                sequence="50"/>
</odoo>