<?xml version="1.0" encoding="utf-8" ?>
<odoo>

<record id="view_split_wiz_form" model="ir.ui.view">
    <field name="name">split.sale.wiz.form</field>
    <field name="model">split.sale.wiz</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <group>
                    <field name="partner_id"/>
                </group>
            </sheet>
             <footer>
                    <button name="action_for_split"
                            type="object"
                            string="Process"
                            class="btn-warning"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
        </form>
    </field>
    </record>

     <record id="action_split" model="ir.actions.act_window">
        <field name="name">Split</field>
        <field name="res_model">split.sale.wiz</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>