<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="sale_order_inherit_view" model="ir.ui.view">
        <field name="name">Sale Order View</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='order_lines']/field[@name='order_line']/tree/field[@name='name']" position="after">
                <field name="is_split"/>
            </xpath>
            <xpath expr="//header/field[@name='state']" position="after">
                <button name="action_split"
                            type="object"
                            string="Split"
                            class="btn-primary"/>
            </xpath>
            <xpath expr="//sheet/notebook/page[@name='order_lines']/field[@name='order_line']/tree/field[@name='name']" position="after">
                <field name="extra_description"/>
            </xpath>
        </field>
    </record>

</odoo>